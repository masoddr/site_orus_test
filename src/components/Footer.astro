---
const currentYear = new Date().getFullYear();
---

<footer class="bg-space-dark py-12 mt-16">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <!-- Logo and Description -->
      <div class="md:col-span-2">
        <a href="/" class="text-2xl font-bold text-space-silver flex items-center gap-2 mb-4">
          <span class="text-space-purple">ORUS</span>
        </a>
        <p class="text-space-silver/60 max-w-md">
          Orus développe des solutions d'observation hyperspectrale innovantes pour répondre aux défis environnementaux et sociétaux de demain.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-bold text-space-silver mb-4">Navigation</h4>
        <ul class="space-y-2">
          <li>
            <a href="#about" class="text-space-silver/60 hover:text-space-purple transition-colors">À propos</a>
          </li>
          <li>
            <a href="#technology" class="text-space-silver/60 hover:text-space-purple transition-colors">Technologie</a>
          </li>
          <li>
            <a href="#applications" class="text-space-silver/60 hover:text-space-purple transition-colors">Applications</a>
          </li>
          <li>
            <a href="#contact" class="text-space-silver/60 hover:text-space-purple transition-colors">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-lg font-bold text-space-silver mb-4">Légal</h4>
        <ul class="space-y-2">
          <li>
            <a href="#" class="text-space-silver/60 hover:text-space-purple transition-colors">Mentions légales</a>
          </li>
          <li>
            <a href="#" class="text-space-silver/60 hover:text-space-purple transition-colors">Politique de confidentialité</a>
          </li>
          <li>
            <a href="#" class="text-space-silver/60 hover:text-space-purple transition-colors">CGU</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-space-silver/10 pt-8 mt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-space-silver/60 text-sm">
        © {currentYear} Orus. Tous droits réservés.
      </p>
      <div class="flex space-x-4 mt-4 md:mt-0">
        <a href="https://www.linkedin.com/company/orusspace/" class="text-space-silver/60 hover:text-space-purple transition-colors" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">LinkedIn</span>
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer> 